{
  "name": "@bitcraft/pi-web-tools",
  "version": "0.1.1",
  "description": "Shell-only web search and fetch tools for pi.dev. No API keys.",
  "type": "module",
  "main": "./index.ts",
  "license": "MIT",
  "keywords": ["pi-package", "pi-extension", "websearch", "webfetch"],
  "pi": {
    "extensions": ["./index.ts"]
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-ai": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0",
    "vitest": "^3.2.4",
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-ai": "*",
    "typebox": "*"
  },
  "scripts": {
    "test": "vitest --run",
    "test:watch": "vitest",
    "test:network": "RUN_NETWORK_TESTS=1 vitest --run"
  },
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/bitcraft-apps/pi-web-tools.git"
  }
}
