{
  "name": "@bitcraft-apps/pi-web-tools",
  "version": "1.3.0",
  "description": "Shell-only web search and fetch tools for pi.dev. No API keys.",
  "type": "module",
  "main": "./index.ts",
  "license": "MIT",
  "homepage": "https://github.com/bitcraft-apps/pi-web-tools",
  "bugs": "https://github.com/bitcraft-apps/pi-web-tools/issues",
  "keywords": [
    "pi-package",
    "pi-extension",
    "websearch",
    "webfetch"
  ],
  "pi": {
    "extensions": [
      "./index.ts"
    ],
    "image": "https://raw.githubusercontent.com/bitcraft-apps/pi-web-tools/main/.github/preview.png"
  },
  "files": [
    "index.ts",
    "src",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-tui": "^0.73.0",
    "typebox": "*"
  },
  "dependencies": {
    "undici": "^6.0.0 || ^7.0.0"
  },
  "devDependencies": {
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*",
    "@types/node": "^20.0.0",
    "@typescript/native-preview": "7.0.0-dev.20260507.1",
    "oxfmt": "0.48.0",
    "oxlint": "1.63.0",
    "oxlint-tsgolint": "0.22.1",
    "typebox": "*",
    "vitest": "^3.2.4"
  },
  "scripts": {
    "test": "vitest --run",
    "test:watch": "vitest",
    "test:network": "RUN_NETWORK_TESTS=1 vitest --run",
    "typecheck": "tsgo --noEmit -p tsconfig.json",
    "lint": "oxlint --deny-warnings",
    "format": "oxfmt src/ test/ index.ts vitest.config.ts",
    "format:check": "oxfmt --check src/ test/ index.ts vitest.config.ts"
  },
  "engines": {
    "node": ">=22"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bitcraft-apps/pi-web-tools.git"
  }
}
