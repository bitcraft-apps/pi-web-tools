{
  "name": "@bitcraft-apps/pi-web-tools",
  "version": "0.4.1",
  "description": "Shell-only web search and fetch tools for pi.dev. No API keys.",
  "type": "module",
  "main": "./index.ts",
  "license": "MIT",
  "keywords": [
    "pi-package",
    "pi-extension",
    "websearch",
    "webfetch"
  ],
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  },
  "files": [
    "index.ts",
    "src",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-ai": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript/native-preview": "7.0.0-dev.20260507.1",
    "typescript": "^5.4.0",
    "vitest": "^3.2.4",
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-ai": "*",
    "typebox": "*"
  },
  "scripts": {
    "test": "vitest --run",
    "test:watch": "vitest",
    "test:network": "RUN_NETWORK_TESTS=1 vitest --run",
    "typecheck": "tsgo --noEmit -p tsconfig.json"
  },
  "engines": {
    "node": ">=22"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bitcraft-apps/pi-web-tools.git"
  }
}
